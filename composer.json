{
  "name": "rockschtar/wordpress-settings",
  "license": "MIT",
  "description": "WordPress Settings Utility/Helper for usage with roots/bedrock (mu-plugin)",
  "type": "wordpress-muplugin",
  "require": {
    "php": ">=8.3",
    "ext-fileinfo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "brain/monkey": "^2.6",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": {
      "Rockschtar\\WordPress\\Settings\\": "src/",
      "Rockschtar\\WordPress\\Settings\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
